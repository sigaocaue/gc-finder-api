# App
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=sua_chave_secreta_aqui

# Banco de dados
DATABASE_URL=postgresql+asyncpg://gcfinder:gcfinder@db:5432/gcfinder
DATABASE_USE_SSL=false

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_SECRET=seu_access_secret_aqui
JWT_REFRESH_SECRET=seu_refresh_secret_aqui
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Google Maps Geocoding API
GOOGLE_MAPS_API_KEY=sua_chave_google_maps_aqui

# OCR — grupos de dependências a instalar no Docker (separados por vírgula)
# Opções: ocr-tesseract, ocr-documentai
# Exemplo com todos: ocr-tesseract,ocr-documentai
OCR_GROUPS=ocr-tesseract

# OCR — serviços disponíveis neste ambiente (separados por vírgula)
# Deve corresponder aos grupos instalados acima
# Opções: tesseract, google_documentai
OCR_AVAILABLE_SERVICES=tesseract

# Google Document AI (necessário apenas se google_documentai estiver habilitado)
GOOGLE_DOCUMENTAI_PROJECT_ID=
GOOGLE_DOCUMENTAI_LOCATION=us
GOOGLE_DOCUMENTAI_PROCESSOR_ID=
# JSON da service account do Google Cloud (conteúdo completo do arquivo .json, em uma linha)
# Obtenha em: Google Cloud Console > IAM > Service Accounts > Keys > Create new key (JSON)
GOOGLE_CLOUD_CREDENTIALS_JSON=

# Google Forms — URL de submissão do formulário da Lagoinha
GOOGLE_FORMS_SUBMIT_URL=https://docs.google.com/forms/d/e/1FAIpQLSclBf2JMTSZny_8n5eIl4D8TnNUSRPHy42-Bb7RFGf5aww08Q/formResponse

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Variáveis para o Docker Compose (devem coincidir com a URL acima)
POSTGRES_USER=gc_finder_postgres_user
POSTGRES_PASSWORD=gc_finder_postgres_password
POSTGRES_DB=gc_finder_db
POSTGRES_PORT=5432
REDIS_PASSWORD=gc_finder_redis_password